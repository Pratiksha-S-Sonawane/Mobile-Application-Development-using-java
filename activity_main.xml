        android:text="3" />

    <Button
        android:id="@+id/b4"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:text="4" />

    <Button
        android:id="@+id/b5"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:text="5" />

    <Button
        android:id="@+id/b6"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:text="6" />

    <Button
        android:id="@+id/b7"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:text="7" />

    <Button
        android:id="@+id/b8"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:text="8" />

    <EditText

        android:id="@+id/e1"
        android:layout_width="398dp"
        android:layout_height="62dp" />

</LinearLayout>